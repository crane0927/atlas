# ============================================================
# Docker 构建忽略文件
# 用途: 排除不需要复制到 Docker 构建上下文的文件
# ============================================================

# Git
.git/
.gitignore
.gitattributes

# IDE
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath

# Maven 构建输出（构建镜像时会重新生成）
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# 日志文件
*.log
logs/

# 临时文件
*.tmp
*.bak
*.swp
*.swo
*~

# 环境配置（敏感信息）
.env
.env.*
*.env

# 系统文件
.DS_Store
Thumbs.db

# 文档和规格说明（不需要打包到镜像中）
docs/
specs/
*.md
!README.md

# Docker 相关（避免递归复制）
Dockerfile*
docker-compose*.yml
.dockerignore

# 测试相关
test/
tests/
**/src/test/
coverage/

# 其他不需要的文件
.specify/
node_modules/
